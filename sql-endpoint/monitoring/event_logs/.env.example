# ─────────────────────────────────────────────────────────────
# Copy this to .env and fill in your values
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ════════════════════════════════════════
# OCI — REQUIRED
# ════════════════════════════════════════
OCI_NAMESPACE=your-tenancy-namespace
OCI_BUCKET=your-bucket-name
OCI_REGION=us-phoenix-1

# ════════════════════════════════════════
# OCI — AUTH
# ════════════════════════════════════════

# Auth method — choose one:
#   api_key            API key in ~/.oci/config        (default)
#   security_token     Session token (oci session authenticate)
#   instance_principal OCI Compute / OKE node pool
#   resource_principal OCI Functions / OKE workload identity
OCI_CLI_AUTH=api_key

# Named profile in ~/.oci/config to use (default: DEFAULT)
# Create extra profiles with: oci session authenticate --profile MY_PROFILE
OCI_PROFILE=DEFAULT

# Path to OCI config file inside the container
# Change only if you mount the config somewhere other than /root/.oci
OCI_CONFIG_FILE=/root/.oci/config

# Path to your local ~/.oci directory (mounted read-only into the container)
# Not needed for instance_principal / resource_principal
OCI_CONFIG_DIR=~/.oci

# ════════════════════════════════════════
# OCI — OPTIONAL
# ════════════════════════════════════════

# Filter to a subfolder inside the bucket (leave empty for all)
OCI_PREFIX=spark-logs/

# ════════════════════════════════════════
# LOG PREPARER
# ════════════════════════════════════════

# Fluent Bit wrapping detection: auto | true | false
FLUENT_BIT_WRAPPED=auto

# Poll OCI continuously for new logs
WATCH_MODE=true

# Seconds between polls (watch mode only)
POLL_INTERVAL=300

# Keep raw downloaded files after processing
KEEP_RAW=false

# Verbose debug output
DEBUG=false

# Repair SHS event-log data before Spark History Server reads it
SPARK_EVENT_REPAIR_ENABLED=true
SPARK_EVENT_MAX_STRING_CHARS=18000000
SPARK_EVENT_REPAIR_REPORT_DIR=/shs-logs/_repair-reports

# ════════════════════════════════════════
# SPARK EVENT LOG AGENT
# ════════════════════════════════════════

# Analyze normalized Spark event logs and write JSON/Markdown reports
SPARK_EVENT_AGENT_ENABLED=true

# Reports are written under the mounted SHS output directory
SPARK_EVENT_AGENT_REPORT_DIR=/shs-logs/_agent-reports

# Seconds between checks in watch mode
SPARK_EVENT_AGENT_INTERVAL=300

# Bounded per-stage metric samples retained for skew/median checks
SPARK_EVENT_AGENT_MAX_SAMPLES=5000

# Stream existing Spark History Server eventlog_v2_* directories.
# This mode first parses root-cause event types, then TaskEnd metrics only
# for failed or signature-bearing stages.
SPARK_EVENT_AGENT_LARGE_SHS_MODE=false
SPARK_EVENT_AGENT_LARGE_SHS_MAX_STAGES=50

# Finding thresholds
SPARK_EVENT_AGENT_SPILL_WARN_BYTES=1073741824
SPARK_EVENT_AGENT_GC_WARN_RATIO=0.10
SPARK_EVENT_AGENT_GC_CRITICAL_RATIO=0.25
SPARK_EVENT_AGENT_SKEW_RATIO=5.0

# ════════════════════════════════════════
# SPARK HISTORY SERVER
# ════════════════════════════════════════
SHS_PORT=18080
SHS_MAX_APPLICATIONS=500
SHS_RETAINED_APPLICATIONS=100
SHS_UPDATE_INTERVAL=10s
SHS_CLEANER_ENABLED=false
SHS_ACLS_ENABLED=false
